# ──────────────────────────────────────────────
#  CatalogFlow — Variáveis de Ambiente
# ──────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores reais.
# Nunca commite .env (já está no .gitignore).

# ── Ambiente ──────────────────────────────────
ENVIRONMENT=development
# development | staging | production
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR

# ── Banco de dados (PostgreSQL 16) ────────────
# Em docker-compose: usar host "postgres". Em host local: usar "localhost".
DATABASE_URL=postgresql+asyncpg://catalogflow:catalogflow@postgres:5432/catalogflow
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# Credenciais usadas pelo container postgres (compose)
POSTGRES_USER=catalogflow
POSTGRES_PASSWORD=catalogflow
POSTGRES_DB=catalogflow

# ── Cache / Broker (Redis 7) ──────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_RESULT_TTL_SECONDS=86400

# ── Storage (S3 / Cloudflare R2) ──────────────
# Em dev local: MinIO ou stub. Em produção: R2.
S3_BUCKET=catalogflow-dev
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=auto
AWS_ACCESS_KEY_ID=minio-dev-key
AWS_SECRET_ACCESS_KEY=minio-dev-secret
S3_PRESIGNED_URL_TTL_SECONDS=3600

# ── Segurança ─────────────────────────────────
# Gerar com: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production-use-a-64-char-random-secret
ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Token para rotas internas /internal/* (criação de brand, etc.)
# Gerar com: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SECRET=change-me-internal-only-not-exposed-to-clients

# Prefixo das API keys públicas — não alterar após go-live
API_KEY_PREFIX=cf_

# ── Limites de upload e quota ─────────────────
MAX_PDF_SIZE_MB=50
MAX_CONCURRENT_JOBS_STARTER=5
MAX_CONCURRENT_JOBS_GROWTH=20
RATE_LIMIT_PER_MINUTE=100

# ── CORS ──────────────────────────────────────
# Lista separada por vírgula. Use ["*"] apenas em dev.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Observabilidade (opcional) ────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development

# ── PyMuPDF licensing (ADR-004) ───────────────
# Defina como "commercial" antes do go-live em produção.
PYMUPDF_LICENSE_MODE=agpl-internal
